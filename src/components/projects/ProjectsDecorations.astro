---
import './ProjectsDecorations.css';
// Hand-drawn doodles for the Projects section: pushpins, ship-it stamp, paper clips.
---

<div class="proj-dec" aria-hidden="true" data-reveal>
  <svg class="p p-pin" viewBox="0 0 40 50" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="currentColor"
      fill="none"
      stroke-width="1.6"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="20" cy="14" r="10" fill="var(--color-red-ink)" stroke="none"></circle>
      <circle cx="20" cy="14" r="10"></circle>
      <line x1="20" y1="24" x2="20" y2="46" stroke-width="2"></line>
      <ellipse cx="16" cy="11" rx="3" ry="2" fill="var(--color-paper)" stroke="none" opacity="0.7"
      ></ellipse>
    </g>
  </svg>

  <svg class="p p-clip" viewBox="0 0 40 60" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="currentColor"
      fill="none"
      stroke-width="1.7"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path
        d="M 14 6 Q 26 6, 26 18 L 26 42 Q 26 52, 18 52 Q 10 52, 10 44 L 10 22 Q 10 14, 16 14 Q 22 14, 22 22 L 22 40"
      ></path>
    </g>
  </svg>

  <svg class="p p-stamp" viewBox="0 0 100 50" xmlns="http://www.w3.org/2000/svg">
    <g stroke="var(--color-red-ink)" fill="none" stroke-width="1.8" stroke-linejoin="round">
      <rect x="4" y="6" width="92" height="38" rx="2"></rect>
      <rect x="8" y="10" width="84" height="30" rx="1" stroke-dasharray="3 2"></rect>
      <text
        x="50"
        y="32"
        text-anchor="middle"
        font-family="JetBrains Mono"
        font-size="16"
        font-weight="700"
        fill="var(--color-red-ink)"
        stroke="none">SHIP IT!</text
      >
    </g>
  </svg>

  <svg class="p p-rocket" viewBox="0 0 60 80" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="currentColor"
      fill="none"
      stroke-width="1.7"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M 30 8 Q 44 22, 44 40 L 44 54 L 16 54 L 16 40 Q 16 22, 30 8 Z"></path>
      <circle cx="30" cy="32" r="5"></circle>
      <path d="M 16 44 L 6 50 L 12 60 L 16 54 Z"></path>
      <path d="M 44 44 L 54 50 L 48 60 L 44 54 Z"></path>
      <path
        d="M 22 60 Q 22 70, 26 76 M 30 60 Q 30 72, 30 78 M 38 60 Q 38 70, 34 76"
        stroke="var(--color-red-ink)"
        stroke-width="2"></path>
    </g>
  </svg>

  <svg class="p p-tag" viewBox="0 0 70 40" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="currentColor"
      fill="none"
      stroke-width="1.6"
      stroke-linejoin="round"
      stroke-linecap="round"
    >
      <path
        d="M 6 8 L 50 8 L 64 20 L 50 32 L 6 32 Z"
        fill="var(--color-highlight)"
        fill-opacity="0.6"></path>
      <circle cx="14" cy="20" r="2" fill="currentColor"></circle>
      <text
        x="32"
        y="25"
        text-anchor="middle"
        font-family="Caveat"
        font-size="16"
        fill="currentColor"
        stroke="none">v1.0</text
      >
    </g>
  </svg>
</div>

---
interface Props {
  title: string;
  /** Chapter / page label rendered above the title (e.g. "CH. 02"). */
  chapter?: string;
  /** Optional small label rendered next to the title (e.g. "* the boring bit"). */
  aside?: string;
  /** Choose icon style by content semantic, drawn inline. */
  icon?: 'about' | 'work' | 'skills' | 'contact' | 'experience' | 'none';
}
const { title, chapter, aside, icon = 'none' } = Astro.props;
---

<header class="ch-head">
  <div class="ch-meta">
    {chapter && <span class="ch-num">{chapter}</span>}
    {
      icon !== 'none' && (
        <svg
          class="ch-icon"
          viewBox="0 0 32 32"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <g
            stroke="currentColor"
            fill="none"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            {icon === 'about' && (
              <>
                <circle cx="16" cy="12" r="6" />
                <path d="M 5 28 Q 5 19, 16 19 Q 27 19, 27 28" />
              </>
            )}
            {icon === 'work' && (
              <>
                <rect x="5" y="10" width="22" height="16" rx="2" />
                <path d="M 11 10 V 8 Q 11 6, 13 6 H 19 Q 21 6, 21 8 V 10" />
              </>
            )}
            {icon === 'skills' && (
              <>
                <circle cx="16" cy="16" r="10" />
                <path d="M 11 16 L 14 19 L 21 12" stroke="var(--color-red-ink)" />
              </>
            )}
            {icon === 'contact' && (
              <>
                <rect x="4" y="8" width="24" height="16" rx="2" />
                <path d="M 4 10 L 16 18 L 28 10" />
              </>
            )}
            {icon === 'experience' && (
              <>
                <polyline points="4 24 12 16 18 20 28 8" />
                <path d="M 22 8 H 28 V 14" />
              </>
            )}
          </g>
        </svg>
      )
    }
  </div>
  <h2>
    <span class="head-text">{title}</span>
    {aside && <span class="ch-aside">{aside}</span>}
  </h2>
</header>

<style>
  .ch-head {
    display: block;
    margin-bottom: 48px;
    position: relative;
    z-index: 3;
  }
  .ch-meta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
    transform: rotate(-1deg);
  }
  .ch-num {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--color-paper);
    background: var(--color-red-ink);
    padding: 4px 10px 3px;
    border-radius: 2px;
    box-shadow: 2px 2px 0 var(--color-ink);
    transform: rotate(-1.5deg);
  }
  .ch-icon {
    width: 28px;
    height: 28px;
    color: var(--color-ink);
    transform: rotate(2deg);
  }
  h2 {
    font-family: var(--font-display);
    font-size: clamp(44px, 5.4vw, 72px);
    color: var(--color-ink);
    margin: 0;
    line-height: 1;
    font-weight: 700;
    display: flex;
    align-items: baseline;
    gap: 14px;
    flex-wrap: wrap;
  }
  .head-text {
    position: relative;
    display: inline-block;
  }
  .head-text::after {
    content: '';
    position: absolute;
    left: -3px;
    right: -3px;
    bottom: 4px;
    height: 12px;
    background: var(--color-highlight);
    z-index: -1;
    transform: skewX(-6deg);
  }
  .ch-aside {
    font-family: var(--font-utility);
    font-size: 16px;
    color: var(--color-red-ink);
    font-weight: 400;
    letter-spacing: 0.5px;
    transform: rotate(-2deg);
    align-self: center;
    white-space: nowrap;
  }
  @media (max-width: 600px) {
    .ch-head {
      margin-bottom: 28px;
    }
    h2 {
      gap: 8px;
    }
    .ch-aside {
      font-size: 14px;
      width: 100%;
    }
  }
</style>

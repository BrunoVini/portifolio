---
interface Props {
  /** Optional handwritten label to render inline (e.g. "TURN PAGE →"). */
  label?: string;
  /** Side the label sits on. */
  align?: 'left' | 'center' | 'right';
}
const { label = 'turn page →', align = 'right' } = Astro.props;
const dots = 80;
---

<div class={`tear align-${align}`} aria-hidden="true">
  <svg viewBox={`0 0 ${dots * 8} 24`} xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <line
      x1="0"
      y1="12"
      x2={dots * 8}
      y2="12"
      stroke="var(--color-red-ink)"
      stroke-width="1.5"
      stroke-dasharray="6,4"
      opacity="0.6"></line>
  </svg>
  <span class="scissors">✂</span>
  {label && <span class="tear-label">{label}</span>}
</div>

<style>
  .tear {
    position: relative;
    width: 100%;
    height: 32px;
    margin: 28px 0;
  }
  .tear svg {
    width: 100%;
    height: 24px;
    display: block;
    margin-top: 4px;
  }
  .scissors {
    position: absolute;
    left: 24px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 18px;
    color: var(--color-red-ink);
    background: var(--color-paper-edge);
    padding: 0 6px;
  }
  .tear-label {
    position: absolute;
    top: 50%;
    transform: translateY(-50%) rotate(-1.5deg);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    color: var(--color-red-ink);
    background: var(--color-paper-edge);
    padding: 2px 12px;
    letter-spacing: 1px;
    white-space: nowrap;
  }
  .align-right .tear-label {
    right: 28px;
  }
  .align-center .tear-label {
    left: 50%;
    transform: translate(-50%, -50%) rotate(-1.5deg);
  }
  .align-left .tear-label {
    left: 70px;
  }
  @media (max-width: 600px) {
    .scissors {
      left: 14px;
    }
    .tear-label {
      font-size: 16px;
    }
    .align-right .tear-label {
      right: 14px;
    }
  }
</style>

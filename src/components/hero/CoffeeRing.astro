---
// Decorative coffee ring stain — appears with a soft fade.
---

<div class="coffee" aria-hidden="true"></div>

<style>
  .coffee {
    position: absolute;
    left: 130px;
    bottom: 80px;
    width: 75px;
    height: 75px;
    border: 6px solid var(--color-coffee);
    border-radius: 50%;
    background: radial-gradient(circle, transparent 25%, var(--color-coffee-fill) 65%);
    transform: rotate(-12deg) scale(0.95);
    z-index: 3;
    opacity: 0;
    animation: coffeeIn 0.8s ease-out 3s forwards;
    filter: blur(0.4px);
  }
  @media (max-width: 600px) {
    .coffee {
      left: 64px;
      right: auto;
      bottom: 24px;
      width: 44px;
      height: 44px;
      border-width: 4px;
      transform: rotate(-12deg) scale(0.85);
    }
  }
</style>

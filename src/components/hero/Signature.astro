---
interface Props {
  text?: string;
}
const { text = '~ bruno' } = Astro.props;
---

<div class="signature">{text}</div>

<style>
  .signature {
    position: absolute;
    bottom: 20px;
    right: 100px;
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--color-ink);
    transform: rotate(-3deg);
    z-index: 7;
    opacity: 0;
    animation: fadeIn 0.6s ease-out 3.8s forwards;
  }
  .signature::after {
    content: '';
    display: block;
    width: 90px;
    height: 2px;
    background: var(--color-ink);
    margin-top: 4px;
    transform: rotate(-2deg);
    transform-origin: left;
  }
  @media (max-width: 600px) {
    .signature {
      position: static;
      margin: 60px 28px 8px auto;
      text-align: right;
      padding-right: 6px;
      font-size: 22px;
    }
    .signature::after {
      margin-left: auto;
    }
  }
</style>

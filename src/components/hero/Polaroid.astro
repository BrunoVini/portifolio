---
interface Props {
  caption: string;
}
const { caption } = Astro.props;
---

<div class="polaroid">
  <div class="polaroid-img">
    <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect width="100" height="100" fill="var(--color-ink)"></rect>
      <g stroke="#7ab68b" stroke-width="1" fill="none" stroke-linecap="round" opacity="0.9">
        <polyline points="10,80 30,60 45,68 65,40 85,50"></polyline>
        <line x1="10" y1="90" x2="90" y2="90"></line>
        <line x1="10" y1="80" x2="10" y2="90"></line>
      </g>
      <text x="14" y="22" font-family="JetBrains Mono" font-size="8" fill="#7ab68b" opacity="0.9"
        >$ uptime</text
      >
      <text x="14" y="34" font-family="JetBrains Mono" font-size="6" fill="#7ab68b" opacity="0.6"
        >99.97%</text
      >
    </svg>
  </div>
  <div class="polaroid-caption">{caption}</div>
</div>

<style>
  .polaroid {
    position: absolute;
    right: 26%;
    top: 25%;
    width: 130px;
    background: var(--color-paper);
    padding: 8px 8px 22px;
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.18);
    transform: rotate(5deg);
    z-index: 6;
    opacity: 0;
    animation: stickyIn 0.5s ease-out 3.4s forwards;
    border: 1px solid rgba(0, 0, 0, 0.05);
  }
  .polaroid-img {
    aspect-ratio: 1;
    background: var(--color-ink);
    position: relative;
    overflow: hidden;
  }
  .polaroid-img svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .polaroid-caption {
    font-family: var(--font-display);
    font-size: 14px;
    color: var(--color-ink);
    text-align: center;
    margin-top: 6px;
  }
  @media (max-width: 979px) and (min-width: 601px) {
    .polaroid {
      width: 110px;
      right: 28%;
      top: 26%;
    }
  }
  @media (max-width: 600px) {
    .polaroid {
      display: none;
    }
  }
</style>

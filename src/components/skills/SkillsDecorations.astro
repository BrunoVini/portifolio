---
import './SkillsDecorations.css';
// Scattered hand-drawn tech doodles to bring the Skills section to life.
---

<div class="dec" aria-hidden="true" data-reveal>
  <svg class="d d-braces" viewBox="0 0 60 80" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="currentColor"
      fill="none"
      stroke-width="2.2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M 18 8 Q 8 8, 8 22 L 8 36 Q 8 40, 4 40 Q 8 40, 8 44 L 8 58 Q 8 72, 18 72"></path>
      <path d="M 42 8 Q 52 8, 52 22 L 52 36 Q 52 40, 56 40 Q 52 40, 52 44 L 52 58 Q 52 72, 42 72"
      ></path>
      <line x1="24" y1="40" x2="36" y2="40" opacity="0.6"></line>
    </g>
  </svg>
  <svg class="d d-react" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
    <g stroke="currentColor" fill="none" stroke-width="1.6">
      <ellipse cx="40" cy="40" rx="32" ry="12"></ellipse>
      <ellipse cx="40" cy="40" rx="32" ry="12" transform="rotate(60 40 40)"></ellipse>
      <ellipse cx="40" cy="40" rx="32" ry="12" transform="rotate(-60 40 40)"></ellipse>
      <circle cx="40" cy="40" r="4" fill="currentColor"></circle>
    </g>
  </svg>
  <svg class="d d-node" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="currentColor"
      fill="none"
      stroke-width="2"
      stroke-linejoin="round"
      stroke-linecap="round"
    >
      <polygon points="40 8 68 24 68 56 40 72 12 56 12 24"></polygon>
      <text
        x="40"
        y="48"
        text-anchor="middle"
        font-family="JetBrains Mono"
        font-size="16"
        fill="currentColor"
        stroke="none"
        font-weight="700">JS</text
      >
    </g>
  </svg>
  <svg class="d d-term" viewBox="0 0 90 60" xmlns="http://www.w3.org/2000/svg">
    <g stroke="currentColor" fill="none" stroke-width="1.6" stroke-linejoin="round">
      <rect x="4" y="6" width="82" height="48" rx="4"></rect>
      <line x1="4" y1="16" x2="86" y2="16"></line>
      <circle cx="12" cy="11" r="1.6" fill="currentColor"></circle>
      <circle cx="20" cy="11" r="1.6" fill="currentColor"></circle>
      <circle cx="28" cy="11" r="1.6" fill="currentColor"></circle>
      <text
        x="12"
        y="32"
        font-family="JetBrains Mono"
        font-size="9"
        fill="var(--color-red-ink)"
        stroke="none">$ npm test</text
      >
      <text
        x="12"
        y="44"
        font-family="JetBrains Mono"
        font-size="8"
        fill="currentColor"
        stroke="none"
        opacity="0.6">✓ all green</text
      >
    </g>
  </svg>
  <svg class="d d-beaker" viewBox="0 0 50 70" xmlns="http://www.w3.org/2000/svg">
    <g stroke="currentColor" fill="none" stroke-width="1.7" stroke-linecap="round">
      <line x1="14" y1="6" x2="14" y2="38"></line>
      <line x1="36" y1="6" x2="36" y2="38"></line>
      <path d="M 14 38 Q 14 60, 25 62 Q 36 60, 36 38"></path>
      <line x1="10" y1="6" x2="40" y2="6" stroke-width="2"></line>
      <line x1="14" y1="48" x2="36" y2="48" opacity="0.5"></line>
      <circle cx="22" cy="54" r="2" fill="var(--color-red-ink)" stroke="none"></circle>
      <circle cx="30" cy="50" r="1.5" fill="var(--color-red-ink)" stroke="none"></circle>
    </g>
  </svg>
  <svg class="d d-bolt" viewBox="0 0 40 60" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linejoin="round"
      stroke-linecap="round"
      fill="var(--color-highlight)"
      fill-opacity="0.7"
    >
      <polygon points="22 4 6 32 18 32 14 56 34 26 22 26 26 4"></polygon>
    </g>
  </svg>
  <svg class="d d-db" viewBox="0 0 60 70" xmlns="http://www.w3.org/2000/svg">
    <g stroke="currentColor" fill="none" stroke-width="1.7" stroke-linecap="round">
      <ellipse cx="30" cy="12" rx="22" ry="6"></ellipse>
      <path d="M 8 12 L 8 56 Q 8 62, 30 62 Q 52 62, 52 56 L 52 12"></path>
      <ellipse cx="30" cy="32" rx="22" ry="6" opacity="0.6"></ellipse>
      <ellipse cx="30" cy="48" rx="22" ry="6" opacity="0.4"></ellipse>
    </g>
  </svg>
  <svg class="d d-sparkles" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="var(--color-red-ink)"
      stroke-width="1.5"
      stroke-linecap="round"
      fill="var(--color-red-ink)"
      fill-opacity="0.9"
    >
      <path d="M 30 6 L 33 22 L 48 26 L 33 30 L 30 46 L 27 30 L 12 26 L 27 22 Z"></path>
    </g>
    <g
      stroke="var(--color-red-ink)"
      stroke-width="1.2"
      stroke-linecap="round"
      fill="var(--color-red-ink)"
      fill-opacity="0.7"
    >
      <path d="M 50 38 L 52 46 L 58 48 L 52 50 L 50 58 L 48 50 L 42 48 L 48 46 Z"></path>
    </g>
  </svg>
  <svg class="d d-coffee" viewBox="0 0 60 50" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="currentColor"
      fill="none"
      stroke-width="1.6"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="10" y="16" width="34" height="26" rx="2"></rect>
      <path d="M 44 22 Q 54 22, 54 30 Q 54 38, 44 38" stroke-width="1.5"></path>
      <path d="M 18 10 Q 22 6, 18 2" opacity="0.55"></path>
      <path d="M 26 10 Q 30 6, 26 2" opacity="0.55"></path>
      <path d="M 34 10 Q 38 6, 34 2" opacity="0.55"></path>
    </g>
  </svg>
  <svg class="d d-arrow" viewBox="0 0 100 40" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="var(--color-red-ink)"
      stroke-width="1.7"
      fill="none"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M 4 28 Q 30 8, 70 18 Q 80 20, 92 24"></path>
      <path d="M 82 18 L 92 24 L 84 32"></path>
    </g>
  </svg>
  <svg class="d d-star" viewBox="0 0 30 30" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="var(--color-red-ink)"
      fill="var(--color-highlight)"
      fill-opacity="0.7"
      stroke-width="1.5"
      stroke-linejoin="round"
    >
      <path d="M 15 3 L 18 12 L 27 13 L 20 19 L 22 28 L 15 23 L 8 28 L 10 19 L 3 13 L 12 12 Z"
      ></path>
    </g>
  </svg>
  <svg class="d d-heart" viewBox="0 0 40 36" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="var(--color-red-ink)"
      stroke-width="1.6"
      fill="var(--color-red-ink)"
      fill-opacity="0.8"
      stroke-linejoin="round"
    >
      <path
        d="M 20 32 C 8 22, 4 14, 8 8 C 12 2, 18 4, 20 10 C 22 4, 28 2, 32 8 C 36 14, 32 22, 20 32 Z"
      ></path>
    </g>
  </svg>
</div>

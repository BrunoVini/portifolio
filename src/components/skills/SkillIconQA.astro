---
type Kind = 'tdd' | 'e2e' | 'cicd' | 'claude' | 'cursor' | 'agents';
interface Props {
  kind: Kind;
}
const { kind } = Astro.props;
---

<g
  stroke="var(--color-ink)"
  fill="none"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
>
  {
    kind === 'tdd' && (
      <>
        <circle cx="12" cy="12" r="10" fill="var(--color-paper)" />
        <path d="M 7 12 L 11 16 L 17 8" stroke="var(--color-red-ink)" stroke-width="2.4" />
      </>
    )
  }
  {
    kind === 'e2e' && (
      <>
        <line x1="9" y1="2" x2="9" y2="14" />
        <line x1="15" y1="2" x2="15" y2="14" />
        <path
          d="M 9 14 Q 9 21, 12 22 Q 15 21, 15 14 Z"
          fill="var(--color-red-ink)"
          fill-opacity="0.5"
        />
        <line x1="7" y1="2" x2="17" y2="2" stroke-width="2" />
      </>
    )
  }
  {
    kind === 'cicd' && (
      <polygon points="13 2 5 13 11 13 9 22 19 11 13 11 15 2" fill="var(--color-highlight)" />
    )
  }
  {
    kind === 'claude' && (
      <path
        d="M 12 2 L 13 10 L 21 11 L 13 12 L 12 22 L 11 12 L 3 11 L 11 10 Z"
        fill="var(--color-red-ink)"
        stroke="var(--color-red-ink)"
      />
    )
  }
  {
    kind === 'cursor' && (
      <>
        <polygon points="4 3 4 18 9 14 12 21 14 20 11 13 17 13" fill="var(--color-paper)" />
        <path
          d="M 18 4 L 19 7 L 22 8 L 19 9 L 18 12 L 17 9 L 14 8 L 17 7 Z"
          fill="var(--color-red-ink)"
          stroke="var(--color-red-ink)"
        />
      </>
    )
  }
  {
    kind === 'agents' && (
      <>
        <rect x="4" y="6" width="16" height="14" rx="2" fill="var(--color-paper)" />
        <line x1="12" y1="2" x2="12" y2="6" />
        <circle cx="12" cy="3" r="1" fill="var(--color-ink)" />
        <circle cx="9" cy="12" r="1.5" fill="var(--color-ink)" />
        <circle cx="15" cy="12" r="1.5" fill="var(--color-ink)" />
        <path d="M 9 16 Q 12 18, 15 16" />
      </>
    )
  }
</g>

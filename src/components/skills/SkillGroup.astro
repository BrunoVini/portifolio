---
import CategoryIcon from './CategoryIcon.astro';
import SkillIcon from './SkillIcon.astro';
interface Props {
  category: string;
  items: { name: string; note?: string; featured?: boolean }[];
}
const { category, items } = Astro.props;
---

<section class="grp" data-reveal>
  <header class="grp-head">
    <CategoryIcon name={category} />
    <h3>{category}</h3>
  </header>
  <ul>
    {
      items.map((it, i) => (
        <li class={`badge i-${i % 5} ${it.featured ? 'featured' : ''}`}>
          <SkillIcon name={it.name} />
          <span class="badge-text">{it.name}</span>
          {it.note && <span class="note"> — {it.note}</span>}
        </li>
      ))
    }
  </ul>
</section>

<style>
  .grp {
    margin-bottom: 36px;
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.6s ease-out,
      transform 0.6s ease-out;
  }
  .grp.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }
  .grp-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }
  h3 {
    font-family: var(--font-display);
    font-size: 28px;
    color: var(--color-ink);
    margin: 0;
  }
  ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px 12px;
  }
  .badge {
    font-family: var(--font-utility);
    font-size: 16px;
    padding: 8px 14px 8px 10px;
    background: transparent;
    color: var(--color-ink);
    border: 1.5px solid var(--color-ink);
    border-radius: 14px 18px 16px 20px / 22px 16px 24px 18px;
    transform-origin: center;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    cursor: default;
    transition:
      transform 0.18s var(--ease-soft),
      box-shadow 0.18s ease,
      background 0.18s ease;
  }
  .badge:hover {
    transform: rotate(0) scale(1.06) translateY(-2px);
    box-shadow: 2px 2px 0 var(--color-ink);
    background: var(--color-highlight-soft);
    z-index: 2;
  }
  .badge.featured:hover {
    box-shadow: 3px 3px 0 var(--color-red-ink);
  }
  .badge-text {
    line-height: 1;
  }
  .badge.i-0 {
    transform: rotate(-1.5deg);
  }
  .badge.i-1 {
    transform: rotate(1.2deg);
  }
  .badge.i-2 {
    transform: rotate(-0.6deg);
  }
  .badge.featured {
    background: var(--color-highlight-soft);
    border-color: var(--color-ink);
    border-width: 2px;
    box-shadow: 2px 2px 0 var(--color-ink);
  }
  .badge.i-3 {
    transform: rotate(2deg);
  }
  .badge.i-4 {
    transform: rotate(-2deg);
  }
  .note {
    color: var(--color-ink-soft);
    font-size: 14px;
  }
</style>

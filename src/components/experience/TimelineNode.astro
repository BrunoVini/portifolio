---
import { assetUrl } from '../../lib/asset';
import SoundEffect from '../ui/SoundEffect.astro';
import StatBadge from './StatBadge.astro';
import type { ResolvedExperienceStat } from '../../lib/types';
import './TimelineNode.css';
interface Props {
  company: string;
  companyLogo?: string;
  location?: string;
  employmentType?: string;
  role: string;
  startDate: string;
  endDate: string;
  description: string;
  highlights: string[];
  stats?: ResolvedExperienceStat[];
  current?: boolean;
}
const {
  company,
  companyLogo,
  location,
  employmentType,
  role,
  startDate,
  endDate,
  description,
  highlights,
  stats,
  current = false,
} = Astro.props;
const initials = company
  .split(/\s+/)
  .map((w) => w[0])
  .slice(0, 2)
  .join('')
  .toUpperCase();
const logoSrc = companyLogo ? assetUrl(companyLogo, import.meta.env.BASE_URL) : undefined;
---

<article class={`node ${current ? 'is-current' : ''}`} data-reveal>
  <div class="logo" aria-hidden="true">
    {
      logoSrc ? (
        <img src={logoSrc} alt="" loading="lazy" />
      ) : (
        <span class="initials">{initials}</span>
      )
    }
  </div>
  {
    current && (
      <span class="current-sfx">
        <SoundEffect text="NOW!" color="red" rotate={14} size={64} />
      </span>
    )
  }
  <header class="hd">
    <h3>{role}</h3>
    <span class="company">{company}</span>
    {employmentType && <span class="emp">· {employmentType}</span>}
    <time>
      {startDate} → {endDate}
    </time>
  </header>
  {location && <p class="loc">{location}</p>}
  {
    stats && stats.length > 0 && (
      <div class="stats-row">
        {stats.map((s) => (
          <StatBadge label={s.label} icon={s.icon} />
        ))}
      </div>
    )
  }
  <p class="desc">{description}</p>
  {
    highlights.length > 0 && (
      <ul>
        {highlights.map((h) => (
          <li>{h}</li>
        ))}
      </ul>
    )
  }
</article>

---
import { assetUrl } from '../../lib/asset';
import SoundEffect from '../ui/SoundEffect.astro';
import StatBadge from './StatBadge.astro';
import type { ResolvedExperienceStat } from '../../lib/types';
import './TimelineNode.css';
interface Props {
  company: string;
  companyLogo?: string;
  location?: string;
  employmentType?: string;
  role: string;
  startDate: string;
  endDate: string;
  description: string;
  highlights: string[];
  stats?: ResolvedExperienceStat[];
  current?: boolean;
  kind?: 'work' | 'education';
  schoolLabel?: string;
  defaultOpen?: boolean;
  index: number;
  toggleHint: string;
}
const {
  company,
  companyLogo,
  location,
  employmentType,
  role,
  startDate,
  endDate,
  description,
  highlights,
  stats,
  current = false,
  kind,
  schoolLabel,
  defaultOpen = false,
  index,
  toggleHint,
} = Astro.props;
const initials = company
  .split(/\s+/)
  .map((w) => w[0])
  .slice(0, 2)
  .join('')
  .toUpperCase();
const logoSrc = companyLogo ? assetUrl(companyLogo, import.meta.env.BASE_URL) : undefined;
const panelId = `exp-panel-${index}`;
const headerId = `exp-header-${index}`;
---

<article
  class={`node ${current ? 'is-current' : ''} ${kind === 'education' ? 'is-school' : ''} ${defaultOpen ? 'is-open' : ''}`}
  data-reveal
  data-accordion-item
>
  {kind === 'education' && schoolLabel && <span class="school-stamp">{schoolLabel}</span>}
  <div class="logo" aria-hidden="true">
    {
      logoSrc ? (
        <img src={logoSrc} alt="" width="48" height="48" loading="lazy" decoding="async" />
      ) : (
        <span class="initials">{initials}</span>
      )
    }
  </div>
  {
    current && (
      <span class="current-sfx">
        <SoundEffect text="NOW!" color="red" rotate={14} size={64} />
      </span>
    )
  }
  <button
    type="button"
    class="exp-toggle"
    id={headerId}
    aria-expanded={defaultOpen ? 'true' : 'false'}
    aria-controls={panelId}
    data-accordion-toggle
  >
    <header class="hd">
      <h3>
        <span class="role-text">{role}</span>
      </h3>
      <span class="company">{company}</span>
      {employmentType && <span class="emp">· {employmentType}</span>}
      <time>
        {startDate} → {endDate}
      </time>
    </header>
    <span class="exp-chevron" aria-hidden="true">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path
          d="M 5 9 Q 12 16, 19 9"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </span>
    <span class="exp-hint" aria-hidden="true">{toggleHint}</span>
  </button>
  <div class="exp-panel" id={panelId} role="region" aria-labelledby={headerId}>
    <div class="exp-panel-inner">
      {location && <p class="loc">{location}</p>}
      {
        stats && stats.length > 0 && (
          <div class="stats-row">
            {stats.map((s) => (
              <StatBadge label={s.label} icon={s.icon} />
            ))}
          </div>
        )
      }
      <p class="desc">{description}</p>
      {
        highlights.length > 0 && (
          <ul>
            {highlights.map((h) => (
              <li>{h}</li>
            ))}
          </ul>
        )
      }
    </div>
  </div>
</article>

---
import type { ExperienceStat } from '../../lib/types';
interface Props {
  label: string;
  icon?: ExperienceStat['icon'];
}
const { label, icon = 'sparkle' } = Astro.props;
---

<span class="stat" data-icon={icon}>
  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <g
      stroke="currentColor"
      fill="none"
      stroke-width="1.7"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      {
        icon === 'chart' && (
          <>
            <polyline points="3 18 8 13 12 16 17 9 21 12" />
            <line x1="3" y1="21" x2="21" y2="21" opacity="0.5" />
          </>
        )
      }
      {
        icon === 'rocket' && (
          <>
            <path d="M 12 3 Q 18 9, 18 15 L 18 19 L 6 19 L 6 15 Q 6 9, 12 3 Z" />
            <circle cx="12" cy="11" r="2" fill="currentColor" />
          </>
        )
      }
      {
        icon === 'tests' && (
          <>
            <line x1="9" y1="3" x2="9" y2="13" />
            <line x1="15" y1="3" x2="15" y2="13" />
            <path
              d="M 9 13 Q 9 20, 12 21 Q 15 20, 15 13 Z"
              fill="currentColor"
              fill-opacity="0.3"
            />
            <line x1="7" y1="3" x2="17" y2="3" stroke-width="2.4" />
          </>
        )
      }
      {
        icon === 'users' && (
          <>
            <circle cx="9" cy="9" r="3" />
            <path d="M 3 19 Q 3 14, 9 14 Q 15 14, 15 19" />
            <circle cx="17" cy="10" r="2.4" />
            <path d="M 14 19 Q 16 16, 21 17" />
          </>
        )
      }
      {
        icon === 'sparkle' && (
          <path
            d="M 12 2 L 13 10 L 21 11 L 13 12 L 12 22 L 11 12 L 3 11 L 11 10 Z"
            fill="currentColor"
            fill-opacity="0.85"
          />
        )
      }
    </g>
  </svg>
  <span class="label">{label}</span>
</span>

<style>
  .stat {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px 4px 6px;
    background: var(--color-paper);
    border: 1.5px solid var(--color-ink);
    border-radius: 999px;
    font-family: var(--font-utility);
    font-size: 13px;
    font-weight: 700;
    color: var(--color-ink);
    transform: rotate(-1deg);
    box-shadow: 1.5px 1.5px 0 var(--color-ink);
    transition:
      transform 0.18s var(--ease-soft),
      box-shadow 0.18s ease;
  }

  .stat[data-icon='rocket'],
  .stat[data-icon='sparkle'] {
    color: var(--color-red-ink);
  }

  .stat[data-icon='chart'],
  .stat[data-icon='tests'] {
    background: var(--color-highlight-soft);
  }

  .stat:nth-child(2n) {
    transform: rotate(1.2deg);
  }

  .stat:nth-child(3n) {
    transform: rotate(-2deg);
  }

  .stat:hover {
    transform: rotate(0) scale(1.06);
    box-shadow: 2.5px 2.5px 0 var(--color-red-ink);
  }

  .stat svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .stat .label {
    line-height: 1;
    white-space: nowrap;
  }
</style>

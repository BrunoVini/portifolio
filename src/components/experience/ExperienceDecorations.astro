---
import './ExperienceDecorations.css';
// Hand-drawn doodles for the Experience section: time, growth, work objects.
---

<div class="exp-dec" aria-hidden="true" data-reveal>
  <svg class="x x-clock" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="currentColor"
      fill="none"
      stroke-width="1.7"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="30" cy="30" r="22"></circle>
      <line x1="30" y1="14" x2="30" y2="18" opacity="0.6"></line>
      <line x1="30" y1="42" x2="30" y2="46" opacity="0.6"></line>
      <line x1="14" y1="30" x2="18" y2="30" opacity="0.6"></line>
      <line x1="42" y1="30" x2="46" y2="30" opacity="0.6"></line>
      <line x1="30" y1="30" x2="30" y2="18" stroke-width="2"></line>
      <line x1="30" y1="30" x2="40" y2="36" stroke-width="2"></line>
      <circle cx="30" cy="30" r="2" fill="currentColor"></circle>
    </g>
  </svg>

  <svg class="x x-cal" viewBox="0 0 56 60" xmlns="http://www.w3.org/2000/svg">
    <g stroke="currentColor" fill="none" stroke-width="1.7" stroke-linejoin="round">
      <rect x="6" y="10" width="44" height="44" rx="3"></rect>
      <line x1="6" y1="20" x2="50" y2="20"></line>
      <line x1="16" y1="4" x2="16" y2="14"></line>
      <line x1="40" y1="4" x2="40" y2="14"></line>
      <rect x="14" y="28" width="6" height="6" fill="var(--color-highlight)" stroke="none"></rect>
      <line x1="24" y1="30" x2="42" y2="30" opacity="0.5"></line>
      <line x1="14" y1="42" x2="30" y2="42" opacity="0.5"></line>
    </g>
  </svg>

  <svg class="x x-growth" viewBox="0 0 100 60" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="var(--color-red-ink)"
      fill="none"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="6 50 26 38 42 44 60 24 80 28 94 12"></polyline>
      <path d="M 84 12 L 94 12 L 94 22"></path>
      <line x1="6" y1="56" x2="94" y2="56" opacity="0.4"></line>
    </g>
  </svg>

  <svg class="x x-bag" viewBox="0 0 60 56" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="currentColor"
      fill="none"
      stroke-width="1.7"
      stroke-linejoin="round"
      stroke-linecap="round"
    >
      <rect x="6" y="16" width="48" height="34" rx="3"></rect>
      <path d="M 22 16 L 22 8 Q 22 6, 24 6 L 36 6 Q 38 6, 38 8 L 38 16"></path>
      <line x1="6" y1="30" x2="54" y2="30" opacity="0.5"></line>
    </g>
  </svg>

  <svg class="x x-pencil" viewBox="0 0 90 30" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="currentColor"
      fill="none"
      stroke-width="1.6"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M 4 14 L 76 14 L 86 22 L 76 30 L 4 30 Z"></path>
      <line x1="76" y1="14" x2="76" y2="30"></line>
      <path d="M 4 14 L 4 30" stroke="var(--color-red-ink)" stroke-width="2.4"></path>
    </g>
  </svg>

  <svg class="x x-check" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="var(--color-red-ink)"
      fill="none"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M 8 22 L 16 30 L 32 12"></path>
    </g>
  </svg>
</div>

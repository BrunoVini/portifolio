---
// Hand-drawn postal-themed doodles, part 2: postmark, curl, sparkle, pen,
// splatter, at, heart. CSS is shared with ContactDecorationsCore.
---

<div class="ct-dec" aria-hidden="true" data-reveal>
  <svg class="c c-postmark" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
    <g stroke="var(--color-red-ink)" fill="none" stroke-width="1.5" stroke-linejoin="round">
      <circle cx="40" cy="40" r="32" stroke-dasharray="3 2"></circle>
      <circle cx="40" cy="40" r="26"></circle>
      <text
        x="40"
        y="32"
        text-anchor="middle"
        font-family="JetBrains Mono"
        font-size="9"
        font-weight="700"
        fill="var(--color-red-ink)"
        stroke="none">2026</text
      >
      <line x1="20" y1="40" x2="60" y2="40"></line>
      <text
        x="40"
        y="54"
        text-anchor="middle"
        font-family="JetBrains Mono"
        font-size="7"
        fill="var(--color-red-ink)"
        stroke="none">PORTIFOLIO</text
      >
    </g>
  </svg>

  <svg class="c c-curl" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
    <g stroke="var(--color-red-ink)" fill="none" stroke-width="1.6" stroke-linecap="round">
      <path d="M 8 30 Q 16 10, 30 14 Q 44 18, 44 32 Q 44 46, 30 46 Q 18 46, 16 36"></path>
      <path d="M 22 32 L 16 36 L 22 42"></path>
    </g>
  </svg>

  <svg class="c c-spark" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="var(--color-red-ink)"
      stroke-width="1.6"
      stroke-linejoin="round"
      fill="var(--color-red-ink)"
      fill-opacity="0.85"
    >
      <path d="M 20 4 L 22 16 L 34 18 L 22 20 L 20 32 L 18 20 L 6 18 L 18 16 Z"></path>
    </g>
  </svg>

  <svg class="c c-pen" viewBox="0 0 90 24" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="currentColor"
      fill="none"
      stroke-width="1.5"
      stroke-linejoin="round"
      stroke-linecap="round"
    >
      <path d="M 4 16 L 70 16 L 86 12 Q 86 16, 86 20 L 70 16" fill="var(--color-paper)"></path>
      <line x1="50" y1="16" x2="50" y2="22" stroke="var(--color-red-ink)" opacity="0.7"></line>
      <line x1="14" y1="16" x2="14" y2="20" stroke-width="1"></line>
    </g>
  </svg>

  <svg class="c c-splatter" viewBox="0 0 60 50" xmlns="http://www.w3.org/2000/svg">
    <g fill="var(--color-red-ink)" stroke="none">
      <circle cx="30" cy="24" r="8" opacity="0.85"></circle>
      <circle cx="42" cy="14" r="3" opacity="0.7"></circle>
      <circle cx="48" cy="22" r="2" opacity="0.8"></circle>
      <circle cx="14" cy="16" r="2" opacity="0.7"></circle>
      <circle cx="20" cy="36" r="1.5" opacity="0.75"></circle>
      <circle cx="40" cy="38" r="2.5" opacity="0.8"></circle>
      <circle cx="52" cy="36" r="1.2" opacity="0.6"></circle>
      <circle cx="6" cy="28" r="1" opacity="0.6"></circle>
    </g>
  </svg>

  <svg class="c c-at" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="currentColor"
      fill="none"
      stroke-width="1.7"
      stroke-linejoin="round"
      stroke-linecap="round"
    >
      <circle cx="30" cy="30" r="22"></circle>
      <circle cx="30" cy="30" r="8"></circle>
      <path d="M 38 30 Q 38 38, 44 38 Q 50 38, 50 30 Q 50 16, 36 14"></path>
    </g>
  </svg>

  <svg class="c c-heart" viewBox="0 0 40 36" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="var(--color-red-ink)"
      stroke-width="1.6"
      fill="var(--color-red-ink)"
      fill-opacity="0.8"
      stroke-linejoin="round"
    >
      <path
        d="M 20 32 C 8 22, 4 14, 8 8 C 12 2, 18 4, 20 10 C 22 4, 28 2, 32 8 C 36 14, 32 22, 20 32 Z"
      ></path>
    </g>
  </svg>
</div>

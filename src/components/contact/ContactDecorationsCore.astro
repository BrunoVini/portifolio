---
import './ContactDecorations.css';
// Hand-drawn postal-themed doodles, part 1: envelope, plane, stamp, wax,
// rotary phone, carrier pigeon.
---

<div class="ct-dec" aria-hidden="true" data-reveal>
  <svg class="c c-envelope" viewBox="0 0 80 56" xmlns="http://www.w3.org/2000/svg">
    <g stroke="currentColor" fill="none" stroke-width="1.7" stroke-linejoin="round">
      <rect x="6" y="10" width="68" height="40" rx="2" fill="var(--color-paper)"></rect>
      <path d="M 6 12 L 40 36 L 74 12"></path>
      <path d="M 6 50 L 28 30" opacity="0.5"></path>
      <path d="M 74 50 L 52 30" opacity="0.5"></path>
    </g>
  </svg>

  <svg class="c c-plane" viewBox="0 0 90 60" xmlns="http://www.w3.org/2000/svg">
    <g stroke="currentColor" fill="none" stroke-width="1.7" stroke-linejoin="round">
      <path d="M 6 32 L 84 8 L 60 56 L 50 36 Z" fill="var(--color-highlight)" fill-opacity="0.5"
      ></path>
      <line x1="6" y1="32" x2="50" y2="36"></line>
      <path
        d="M 12 50 Q 22 44, 30 50"
        stroke="var(--color-red-ink)"
        stroke-width="1.4"
        stroke-dasharray="3 3"></path>
    </g>
  </svg>

  <svg class="c c-stamp" viewBox="0 0 60 70" xmlns="http://www.w3.org/2000/svg">
    <g stroke="var(--color-red-ink)" fill="none" stroke-width="1.6" stroke-linejoin="round">
      <rect x="4" y="4" width="52" height="62" stroke-dasharray="3 2"></rect>
      <rect x="10" y="10" width="40" height="50" stroke-width="1.2"></rect>
      <path
        d="M 30 22 L 32 32 L 42 32 L 34 38 L 36 48 L 30 42 L 24 48 L 26 38 L 18 32 L 28 32 Z"
        fill="var(--color-red-ink)"
        fill-opacity="0.85"></path>
      <text
        x="30"
        y="58"
        text-anchor="middle"
        font-family="Caveat"
        font-size="11"
        font-weight="700"
        fill="var(--color-red-ink)"
        stroke="none">HELLO</text
      >
    </g>
  </svg>

  <svg class="c c-wax" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="var(--color-red-stamp)"
      fill="var(--color-red-ink)"
      fill-opacity="0.85"
      stroke-width="1.6"
      stroke-linejoin="round"
    >
      <path
        d="M 30 6 L 36 14 L 46 14 L 40 22 L 50 26 L 42 32 L 50 40 L 38 42 L 40 52 L 30 48 L 20 52 L 22 42 L 10 40 L 18 32 L 10 26 L 20 22 L 14 14 L 24 14 Z"
      ></path>
      <text
        x="30"
        y="34"
        text-anchor="middle"
        font-family="Caveat"
        font-size="20"
        font-weight="700"
        fill="var(--color-paper)"
        stroke="none">B</text
      >
    </g>
  </svg>

  <svg class="c c-phone" viewBox="0 0 70 70" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="currentColor"
      fill="none"
      stroke-width="1.6"
      stroke-linejoin="round"
      stroke-linecap="round"
    >
      <rect x="10" y="20" width="50" height="42" rx="6"></rect>
      <circle cx="35" cy="38" r="14"></circle>
      <circle cx="35" cy="38" r="5" fill="currentColor"></circle>
      <line x1="35" y1="20" x2="35" y2="14"></line>
      <line x1="35" y1="14" x2="42" y2="10"></line>
      <line x1="42" y1="10" x2="38" y2="6" opacity="0.6"></line>
      <circle cx="35" cy="56" r="2" fill="currentColor"></circle>
      <line x1="20" y1="56" x2="50" y2="56" stroke-width="1" opacity="0.5"></line>
    </g>
  </svg>

  <svg class="c c-pigeon" viewBox="0 0 80 60" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="currentColor"
      fill="var(--color-paper)"
      stroke-width="1.6"
      stroke-linejoin="round"
      stroke-linecap="round"
    >
      <path
        d="M 14 36 Q 12 30, 18 28 Q 28 26, 36 30 L 50 28 Q 60 28, 60 34 Q 58 38, 52 38 L 46 38 L 42 46 L 38 38 L 30 38 Q 22 40, 14 36 Z"
      ></path>
      <circle cx="56" cy="32" r="1.5" fill="currentColor"></circle>
      <path d="M 56 33 L 64 30" stroke-width="1.4"></path>
      <path d="M 24 26 Q 32 18, 40 24" stroke-width="1.4" fill="none"></path>
      <rect
        x="22"
        y="32"
        width="10"
        height="8"
        stroke="var(--color-red-ink)"
        fill="var(--color-paper)"></rect>
      <line x1="22" y1="36" x2="32" y2="36" stroke="var(--color-red-ink)" opacity="0.6"></line>
    </g>
  </svg>

  <svg class="c c-bubble" viewBox="0 0 110 60" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="currentColor"
      fill="var(--color-highlight)"
      fill-opacity="0.55"
      stroke-width="1.6"
      stroke-linejoin="round"
      stroke-linecap="round"
    >
      <path
        d="M 10 14 Q 10 6, 20 6 L 92 6 Q 102 6, 102 14 L 102 36 Q 102 44, 92 44 L 38 44 L 26 56 L 28 44 L 20 44 Q 10 44, 10 36 Z"
      ></path>
      <text
        x="56"
        y="30"
        text-anchor="middle"
        font-family="Caveat"
        font-size="20"
        font-weight="700"
        fill="var(--color-ink)"
        stroke="none">drop me a line!</text
      >
    </g>
  </svg>

  <svg class="c c-compass" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
    <g
      stroke="currentColor"
      fill="none"
      stroke-width="1.6"
      stroke-linejoin="round"
      stroke-linecap="round"
    >
      <circle cx="30" cy="30" r="22"></circle>
      <circle cx="30" cy="30" r="2" fill="currentColor"></circle>
      <path d="M 30 8 L 34 30 L 30 52 L 26 30 Z" fill="var(--color-red-ink)" fill-opacity="0.7"
      ></path>
      <text
        x="30"
        y="6"
        text-anchor="middle"
        font-family="Caveat"
        font-size="10"
        font-weight="700"
        fill="currentColor"
        stroke="none">N</text
      >
      <text
        x="30"
        y="60"
        text-anchor="middle"
        font-family="Caveat"
        font-size="10"
        fill="currentColor"
        stroke="none">S</text
      >
    </g>
  </svg>
</div>

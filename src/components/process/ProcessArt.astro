---
import Sketch from './art/Sketch.astro';
import Tdd from './art/Tdd.astro';
import Build from './art/Build.astro';
import Ship from './art/Ship.astro';

interface Props {
  step: string;
}
const { step } = Astro.props;
---

{step === 'sketch' && <Sketch />}
{step === 'tdd' && <Tdd />}
{step === 'build' && <Build />}
{step === 'ship' && <Ship />}

---
import SectionTitle from '../ui/SectionTitle.astro';
import ProcessDecorations from './ProcessDecorations.astro';
import ProcessArt from './ProcessArt.astro';
import BugMargin from '../ui/BugMargin.astro';
import './Process.css';
import type { Locale } from '../../lib/types';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const panels =
  locale === 'pt'
    ? [
        { n: '1', step: 'sketch', label: 'Rascunho', caption: 'desenha a ideia' },
        { n: '2', step: 'tdd', label: 'TDD', caption: 'red → green' },
        { n: '3', step: 'build', label: 'Build', caption: 'código fluindo' },
        { n: '4', step: 'ship', label: 'Ship', caption: 'entrega 🚀' },
      ]
    : [
        { n: '1', step: 'sketch', label: 'Sketch', caption: 'pencil it out' },
        { n: '2', step: 'tdd', label: 'TDD', caption: 'red → green' },
        { n: '3', step: 'build', label: 'Build', caption: 'flow state' },
        { n: '4', step: 'ship', label: 'Ship', caption: 'shipped 🚀' },
      ];
const aside = locale === 'pt' ? '* o ciclo diário' : '* the daily loop';
const title = locale === 'pt' ? 'Como eu trabalho' : 'How I work';
---

<div class="proc" id="process">
  <ProcessDecorations />
  <BugMargin locale={locale} en="caught. ☹" pt="pego. ☹" position="middle" side="left" />
  <SectionTitle title={title} chapter="PG. 49" icon="experience" aside={aside} />
  <div class="strip">
    {
      panels.map((p, i) => (
        <article class={`panel p-${p.step}`} data-reveal data-tilt style={`--i:${i}`}>
          <span class="num">{p.n}</span>
          <div class="art" aria-hidden="true">
            <ProcessArt step={p.step} />
          </div>
          <div class="caption">
            <strong>{p.label}</strong>
            <span class="sub">{p.caption}</span>
          </div>
        </article>
      ))
    }
  </div>
</div>

---
import SectionTitle from '../ui/SectionTitle.astro';
import ProcessDecorations from './ProcessDecorations.astro';
import './Process.css';
import type { Locale } from '../../lib/types';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const panels =
  locale === 'pt'
    ? [
        { n: '1', step: 'sketch', label: 'Rascunho', caption: 'desenha a ideia' },
        { n: '2', step: 'tdd', label: 'TDD', caption: 'red → green' },
        { n: '3', step: 'build', label: 'Build', caption: 'código fluindo' },
        { n: '4', step: 'ship', label: 'Ship', caption: 'entrega 🚀' },
      ]
    : [
        { n: '1', step: 'sketch', label: 'Sketch', caption: 'pencil it out' },
        { n: '2', step: 'tdd', label: 'TDD', caption: 'red → green' },
        { n: '3', step: 'build', label: 'Build', caption: 'flow state' },
        { n: '4', step: 'ship', label: 'Ship', caption: 'shipped 🚀' },
      ];
const aside = locale === 'pt' ? '* o ciclo diário' : '* the daily loop';
const title = locale === 'pt' ? 'Como eu trabalho' : 'How I work';
---

<div class="proc" id="process">
  <ProcessDecorations />
  <SectionTitle title={title} chapter="PG. 49" icon="experience" aside={aside} />
  <div class="strip">
    {
      panels.map((p, i) => (
        <article class={`panel p-${p.step}`} data-reveal data-tilt style={`--i:${i}`}>
          <span class="num">{p.n}</span>
          <div class="art" aria-hidden="true">
            {p.step === 'sketch' && (
              <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                <g
                  stroke="var(--color-ink)"
                  fill="none"
                  stroke-width="2.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <circle cx="40" cy="38" r="14" fill="var(--color-paper)" />
                  <path d="M 36 32 Q 40 28, 44 32" />
                  <path d="M 36 30 Q 38 26, 41 30" />
                  <path d="M 44 30 Q 46 26, 48 30" />
                  <circle cx="36" cy="38" r="1.4" fill="var(--color-ink)" />
                  <circle cx="44" cy="38" r="1.4" fill="var(--color-ink)" />
                  <path d="M 36 44 Q 40 47, 44 44" />
                  <line x1="40" y1="52" x2="40" y2="68" />
                  <line x1="40" y1="58" x2="32" y2="64" />
                  <line x1="40" y1="58" x2="56" y2="56" />
                  <line x1="56" y1="56" x2="72" y2="40" stroke="var(--color-red-ink)" />
                  <path d="M 70 38 L 76 36 L 78 42 L 72 44 Z" fill="var(--color-paper)" />
                  <rect x="60" y="68" width="34" height="22" rx="2" fill="var(--color-paper)" />
                  <line x1="64" y1="74" x2="84" y2="74" stroke-width="1.2" />
                  <line x1="64" y1="80" x2="80" y2="80" stroke-width="1.2" />
                  <line x1="64" y1="86" x2="76" y2="86" stroke-width="1.2" />
                </g>
              </svg>
            )}
            {p.step === 'tdd' && (
              <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                <g
                  stroke="var(--color-ink)"
                  fill="none"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <line x1="34" y1="14" x2="34" y2="50" />
                  <line x1="58" y1="14" x2="58" y2="50" />
                  <path
                    d="M 34 50 Q 34 84, 46 86 Q 58 84, 58 50 Z"
                    fill="var(--color-red-ink)"
                    fill-opacity="0.55"
                  />
                  <line x1="30" y1="14" x2="62" y2="14" stroke-width="3" />
                  <circle cx="42" cy="74" r="2.2" fill="var(--color-ink)" />
                  <circle cx="50" cy="68" r="1.6" fill="var(--color-ink)" />
                  <text
                    x="78"
                    y="40"
                    font-family="JetBrains Mono"
                    font-weight="700"
                    font-size="11"
                    fill="var(--color-red-ink)"
                    stroke="none"
                  >
                    ✗
                  </text>
                  <text
                    x="78"
                    y="60"
                    font-family="JetBrains Mono"
                    font-weight="700"
                    font-size="11"
                    fill="#3f7d56"
                    stroke="none"
                  >
                    ✓
                  </text>
                  <path d="M 80 50 L 90 50" stroke="var(--color-red-ink)" stroke-width="1.6" />
                  <path
                    d="M 86 46 L 90 50 L 86 54"
                    stroke="var(--color-red-ink)"
                    stroke-width="1.6"
                  />
                </g>
              </svg>
            )}
            {p.step === 'build' && (
              <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                <g
                  stroke="var(--color-ink)"
                  fill="none"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="14" y="32" width="72" height="44" rx="3" fill="var(--color-ink)" />
                  <rect x="20" y="38" width="60" height="32" rx="2" fill="var(--color-ink)" />
                  <line x1="26" y1="46" x2="44" y2="46" stroke="#7ab68b" stroke-width="2" />
                  <line x1="30" y1="54" x2="58" y2="54" stroke="#7ab68b" stroke-width="2" />
                  <line x1="34" y1="62" x2="50" y2="62" stroke="#7ab68b" stroke-width="2" />
                  <rect
                    x="56"
                    y="58"
                    width="6"
                    height="8"
                    fill="#7ab68b"
                    stroke="none"
                    class="build-cursor"
                  />
                  <line x1="14" y1="76" x2="86" y2="76" stroke-width="3" />
                  <ellipse cx="50" cy="82" rx="12" ry="3" />
                  <path
                    d="M 70 18 L 72 26 L 80 28 L 72 30 L 70 38 L 68 30 L 60 28 L 68 26 Z"
                    fill="var(--color-highlight)"
                  />
                </g>
              </svg>
            )}
            {p.step === 'ship' && (
              <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                <g
                  stroke="var(--color-ink)"
                  fill="none"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path
                    d="M 50 14 Q 70 32, 70 56 L 70 76 L 30 76 L 30 56 Q 30 32, 50 14 Z"
                    fill="var(--color-paper)"
                  />
                  <circle cx="50" cy="44" r="6" />
                  <path d="M 30 64 L 18 72 L 24 84 L 30 76 Z" />
                  <path d="M 70 64 L 82 72 L 76 84 L 70 76 Z" />
                  <path
                    d="M 38 80 Q 38 90, 42 96 M 50 80 Q 50 92, 50 98 M 62 80 Q 62 90, 58 96"
                    stroke="var(--color-red-ink)"
                    stroke-width="2.4"
                  />
                  <text
                    x="20"
                    y="22"
                    font-family="Caveat"
                    font-weight="700"
                    font-size="14"
                    fill="var(--color-red-ink)"
                    stroke="none"
                    transform="rotate(-10 20 22)"
                  >
                    SHIPPED!
                  </text>
                </g>
              </svg>
            )}
          </div>
          <div class="caption">
            <strong>{p.label}</strong>
            <span class="sub">{p.caption}</span>
          </div>
        </article>
      ))
    }
  </div>
</div>

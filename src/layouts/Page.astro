---
import '../styles/global.css';
import '../styles/skill-modal.css';
import { assetUrl } from '../lib/asset';
import type { Locale } from '../lib/types';

interface Props {
  locale: Locale;
  title: string;
  description: string;
}
const { locale, title, description } = Astro.props;
const base = import.meta.env.BASE_URL;
const favicon = assetUrl('/favicon.svg', base);

const SITE = 'https://brunovini.github.io';
const trimmedBase = base.replace(/\/$/, '');
const enPath = `${trimmedBase}/`;
const ptPath = `${trimmedBase}/pt/`;
const canonicalPath = locale === 'pt' ? ptPath : enPath;
const canonicalUrl = `${SITE}${canonicalPath}`;
const enUrl = `${SITE}${enPath}`;
const ptUrl = `${SITE}${ptPath}`;
const ogImage = `${SITE}${trimmedBase}/og-image.png`;
const ogLocale = locale === 'pt' ? 'pt_BR' : 'en_US';

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Bruno Vinicius',
  alternateName: 'BrunoVini',
  url: canonicalUrl,
  email: 'mailto:brunovinissouza@gmail.com',
  jobTitle: 'Full-stack JavaScript Developer',
  sameAs: ['https://github.com/BrunoVini', 'https://www.linkedin.com/in/brunovini04'],
};
const skipLabel = locale === 'pt' ? 'pular para o conteúdo' : 'skip to content';
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="Bruno Vinicius" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="pt" href={ptUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personLd)} />
  </head>
  <body>
    <a class="skip-link" href="#main">{skipLabel}</a>
    <main id="main">
      <slot />
    </main>
    <script>
      import { initReveal } from '../lib/reveal';
      import { attachPageFlip } from '../lib/page-flip';
      import { initTilt } from '../lib/tilt';
      import { initRocketCursor } from '../lib/rocket-cursor';
      import { initSkillModal } from '../lib/skill-modal';
      import { initProfilePost } from '../lib/profile-post';
      import { initEasterEggs } from '../lib/easter-eggs';
      import { initProjectFlip } from '../lib/project-flip';
      import { initExperienceAccordion } from '../lib/experience-accordion';
      import { initProcessFlourish } from '../lib/process-flourish';
      const locale = document.documentElement.lang === 'pt' ? 'pt' : 'en';
      initReveal();
      attachPageFlip();
      initTilt();
      initRocketCursor();
      initSkillModal(locale);
      initProfilePost();
      initEasterEggs(locale);
      initProjectFlip();
      initExperienceAccordion();
      initProcessFlourish();
    </script>
  </body>
</html>

<style is:global>
  html,
  body {
    overflow-x: hidden;
    max-width: 100vw;
  }
  main {
    display: block;
  }
</style>

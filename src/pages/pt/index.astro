---
import Page from '../../layouts/Page.astro';
import NotebookPage from '../../components/ui/NotebookPage.astro';
import TearLine from '../../components/ui/TearLine.astro';
import Navigation from '../../components/nav/Navigation.astro';
import Hero from '../../components/hero/Hero.astro';
import About from '../../components/about/About.astro';
import Process from '../../components/process/Process.astro';
import Experience from '../../components/experience/Experience.astro';
import Confessions from '../../components/about/Confessions.astro';
import Projects from '../../components/projects/Projects.astro';
import Skills from '../../components/skills/Skills.astro';
import Contact from '../../components/contact/Contact.astro';

const locale = 'pt' as const;
---

<Page
  locale={locale}
  title="Bruno Vinicius — Desenvolvedor"
  description="Desenvolvedor full-stack JavaScript focado em aplicações escaláveis e de alta performance. TDD, testes end-to-end e CI/CD por padrão."
>
  <NotebookPage>
    <Navigation locale={locale} />
    <Hero locale={locale} />
  </NotebookPage>
  <TearLine />
  <NotebookPage pageNumber={48} static>
    <About locale={locale} />
  </NotebookPage>
  <TearLine />
  <NotebookPage pageNumber={49} static>
    <Process locale={locale} />
  </NotebookPage>
  <TearLine />
  <NotebookPage pageNumber={50} static>
    <Experience locale={locale} />
  </NotebookPage>
  <div class="torn-slot">
    <Confessions locale={locale} />
  </div>
  <NotebookPage pageNumber={51} static>
    <Projects locale={locale} />
  </NotebookPage>
  <TearLine />
  <NotebookPage pageNumber={52} static>
    <Skills locale={locale} />
  </NotebookPage>
  <TearLine />
  <NotebookPage pageNumber={53} static>
    <Contact locale={locale} />
  </NotebookPage>
</Page>

<style>
  .torn-slot {
    padding: 28px 24px 36px;
    background:
      radial-gradient(ellipse at top, var(--color-paper-shadow-strong), transparent 70%),
      var(--color-paper-shadow);
    display: flex;
    justify-content: center;
  }
  @media (max-width: 600px) {
    .torn-slot {
      padding: 18px 14px 22px;
    }
  }
</style>
